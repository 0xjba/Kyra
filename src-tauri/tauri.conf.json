{
  "productName": "Kyra",
  "version": "0.2.0",
  "identifier": "com.kyra.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/0xjba/Kyra/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCQ0U3RUY0MUQ2QzMwMzYKUldRMk1Hd2Q5SDdPNnpGWEdIdnQxeGVWMU8yUm1zYXV4bnllTElLNms0dXNGZjJwUzcyblZ2VkoK"
